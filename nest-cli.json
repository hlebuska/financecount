{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/fincount/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/fincount/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/fincount",
  "projects": {
    "advisor-agent": {
      "type": "application",
      "root": "apps/advisor-agent",
      "entryFile": "main",
      "sourceRoot": "apps/advisor-agent/src",
      "compilerOptions": {
        "tsConfigPath": "apps/advisor-agent/tsconfig.app.json"
      }
    },
    "ai": {
      "type": "library",
      "root": "libs/ai",
      "entryFile": "index",
      "sourceRoot": "libs/ai/src",
      "compilerOptions": {
        "tsConfigPath": "libs/ai/tsconfig.lib.json"
      }
    },
    "analyst-agent": {
      "type": "application",
      "root": "apps/analyst-agent",
      "entryFile": "main",
      "sourceRoot": "apps/analyst-agent/src",
      "compilerOptions": {
        "tsConfigPath": "apps/analyst-agent/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/tsconfig.lib.json"
      }
    },
    "db": {
      "type": "library",
      "root": "libs/db",
      "entryFile": "index",
      "sourceRoot": "libs/db/src",
      "compilerOptions": {
        "tsConfigPath": "libs/db/tsconfig.lib.json"
      }
    },
    "fincount": {
      "type": "application",
      "root": "apps/fincount",
      "entryFile": "main",
      "sourceRoot": "apps/fincount/src",
      "compilerOptions": {
        "tsConfigPath": "apps/fincount/tsconfig.app.json"
      }
    },
    "ingestion-agent": {
      "type": "application",
      "root": "apps/ingestion-agent",
      "entryFile": "main",
      "sourceRoot": "apps/ingestion-agent/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ingestion-agent/tsconfig.app.json"
      }
    },
    "merchant-mcp": {
      "type": "application",
      "root": "apps/merchant-mcp",
      "entryFile": "main",
      "sourceRoot": "apps/merchant-mcp/src",
      "compilerOptions": {
        "tsConfigPath": "apps/merchant-mcp/tsconfig.app.json"
      }
    },
    "rag": {
      "type": "library",
      "root": "libs/rag",
      "entryFile": "index",
      "sourceRoot": "libs/rag/src",
      "compilerOptions": {
        "tsConfigPath": "libs/rag/tsconfig.lib.json"
      }
    }
  }
}