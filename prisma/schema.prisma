generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FileProcessingStatus {
  UPLOADED
  QUEUED
  PROCESSING
  COMPLETED
  COMPLETED_WITH_WARNINGS
  FAILED
  DUPLICATE_FILE
}

enum IngestionFileStage {
  UPLOADING
  QUEUED
  PARSING_FILE
  STRUCTURING_TRANSACTIONS
  PROCESSING_TRANSACTIONS
  CATEGORIZING_TRANSACTIONS
  FINALIZING_FILE
  COMPLETED
  FAILED
  DUPLICATE_FILE
}

enum RawTransactionStatus {
  EXTRACTED
  NORMALIZED
  SKIPPED_DUPLICATE
  INVALID
  NEEDS_REVIEW
}

enum TransactionDirection {
  EXPENSE
  INCOME
}

enum TransactionCategoryStatus {
  NOT_ATTEMPTED
  CATEGORIZED
  UNCATEGORIZED
}

enum ReviewItemStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum ReviewItemType {
  UNCATEGORIZED_TRANSACTION
}

enum AnalysisPeriodType {
  WEEK
  MONTH
  ALL_TIME
}

enum AnalysisDimensionType {
  OVERALL
  CATEGORY
  MERCHANT
}

enum FinancialMetric {
  TOTAL_INCOME
  TOTAL_EXPENSE
  NET_CASHFLOW
  TRANSACTION_COUNT
}

enum AnalysisSignalType {
  CATEGORY_INCREASE
  CATEGORY_DECREASE
  HIGH_UNCATEGORIZED_SHARE
  TOP_CATEGORY_CHANGED
}

enum AnalysisSignalSeverity {
  INFO
  NOTICE
  WARNING
}

enum IngestionIssueSeverity {
  INFO
  WARNING
  ERROR
}

enum IngestionIssueType {
  DUPLICATE_FILE
  PARSE_ERROR
  MALFORMED_TRANSACTION
  AMBIGUOUS_MERCHANT
  DUPLICATE_TRANSACTION
  LOW_CONFIDENCE_CATEGORY
  UNSUPPORTED_FILE_TYPE
  INTERNAL_ERROR
}

model IngestionFile {
  id     String @id @default(cuid())
  userId String

  originalName String
  mimeType     String
  extension    String?
  sizeBytes    Int
  sha256Hash   String
  storagePath       String
  parserOutputText String? @db.Text

  status                 FileProcessingStatus @default(UPLOADED)
  currentStage           IngestionFileStage   @default(UPLOADING)
  currentStageMessage    String?
  progressPercent        Int                  @default(0)
  totalRows              Int                  @default(0)
  processedRows          Int                  @default(0)
  currentRowIndex        Int?
  queueJobId             String?
  processingAttemptCount Int                  @default(0)
  errorMessage           String?

  uploadedAt           DateTime  @default(now())
  processingStartedAt  DateTime?
  processingFinishedAt DateTime?

  extractedTransactionsCount  Int @default(0)
  normalizedTransactionsCount Int @default(0)
  duplicateTransactionsCount  Int @default(0)
  invalidTransactionsCount    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rawTransactions RawExtractedTransaction[]
  issues          IngestionIssue[]
  processingEvents IngestionFileProcessingEvent[]

  @@index([userId, status])
  @@index([userId, sha256Hash])
}

model IngestionFileProcessingEvent {
  id     String @id @default(cuid())
  fileId String

  stage    IngestionFileStage
  message  String
  metadata Json?

  createdAt DateTime @default(now())

  file IngestionFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId, createdAt])
}

model RawExtractedTransaction {
  id     String @id @default(cuid())
  fileId String
  userId String

  sourceRowIndex Int?

  rawDescription   String?
  rawAmountText    String?
  rawCurrencyText  String?
  rawDirectionText String?
  rawDateText      String?

  normalizedAmount            Decimal?              @db.Decimal(14, 2)
  normalizedCurrency          String?
  normalizedDirection         TransactionDirection?
  normalizedOccurredAt        DateTime?
  normalizedMerchantCandidate String?
  sourceFingerprint           String?
  fuzzyFingerprint            String?

  rawPayload Json?

  status           RawTransactionStatus @default(EXTRACTED)
  parserConfidence Float?
  skipReason       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  file               IngestionFile             @relation(fields: [fileId], references: [id], onDelete: Cascade)
  transaction        Transaction?
  merchantEnrichment MerchantEnrichmentResult?
  issues             IngestionIssue[]
  reviewItems        ReviewItem[]

  @@index([fileId])
  @@index([userId, status])
}

model Transaction {
  id     String @id @default(cuid())
  userId String

  rawExtractedTransactionId String? @unique

  amount     Decimal              @db.Decimal(14, 2)
  currency   String
  direction  TransactionDirection
  occurredAt DateTime

  rawMerchantLabel       String?
  normalizedMerchantName String?
  categoryId             String?
  categoryStatus         TransactionCategoryStatus @default(NOT_ATTEMPTED)
  businessType           String?
  merchantConfidence     Float?
  sourceFingerprint      String?
  fuzzyFingerprint       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category                Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  rawExtractedTransaction RawExtractedTransaction? @relation(fields: [rawExtractedTransactionId], references: [id], onDelete: SetNull)
  reviewItems             ReviewItem[]

  @@index([userId, occurredAt])
  @@index([userId, amount, occurredAt])
  @@index([userId, sourceFingerprint])
}

model ReviewItem {
  id String @id @default(cuid())

  userId String

  rawExtractedTransactionId String?
  transactionId            String?

  type    ReviewItemType
  status  ReviewItemStatus @default(OPEN)
  message String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rawExtractedTransaction RawExtractedTransaction? @relation(fields: [rawExtractedTransactionId], references: [id], onDelete: Cascade)
  transaction            Transaction?            @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([rawExtractedTransactionId])
  @@index([transactionId])
}

model Category {
  id   String @id @default(cuid())
  slug String @unique
  name String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
}

model AnalysisRefreshRequest {
  id String @id @default(cuid())

  userId String @unique

  dirtyWeekStarts  Json?
  dirtyMonthStarts Json?
  latestReason     String?
  queuedJobId      String?

  requestedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FinancialStat {
  id String @id @default(cuid())

  userId String

  periodType  AnalysisPeriodType
  periodStart DateTime
  periodEnd   DateTime

  dimensionType AnalysisDimensionType
  dimensionKey  String?
  dimensionLabel String?

  metric   FinancialMetric
  value    Float
  currency String?

  computedAt DateTime @default(now())

  @@index([userId, periodType, periodStart])
  @@index([userId, dimensionType, metric])
}

model AnalysisSignal {
  id String @id @default(cuid())

  userId String

  type     AnalysisSignalType
  severity AnalysisSignalSeverity

  periodType  AnalysisPeriodType
  periodStart DateTime
  periodEnd   DateTime

  dimensionKey   String?
  dimensionLabel String?
  currency       String?

  title       String
  description String
  evidenceJson Json?

  computedAt DateTime @default(now())

  @@index([userId, periodType, periodStart])
  @@index([userId, type, computedAt])
}

model MerchantEnrichmentResult {
  id String @id @default(cuid())

  rawExtractedTransactionId String @unique

  normalizedMerchantName String?
  likelyCategory         String?
  businessType           String?
  confidence             Float?

  ambiguityFlags Json?
  rawResponse    Json?

  createdAt DateTime @default(now())

  rawExtractedTransaction RawExtractedTransaction @relation(fields: [rawExtractedTransactionId], references: [id], onDelete: Cascade)
}

model IngestionIssue {
  id String @id @default(cuid())

  fileId                    String?
  rawExtractedTransactionId String?

  severity IngestionIssueSeverity
  type     IngestionIssueType

  message String
  details Json?

  createdAt DateTime @default(now())

  file                    IngestionFile?           @relation(fields: [fileId], references: [id], onDelete: Cascade)
  rawExtractedTransaction RawExtractedTransaction? @relation(fields: [rawExtractedTransactionId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([rawExtractedTransactionId])
}
